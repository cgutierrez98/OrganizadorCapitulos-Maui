@using organizadorCapitulos.Core.Enums

<section class="editor-card">
    <div class="editor-card-header">
        <span class="panel-kicker">Estrategia</span>
        <h3 class="editor-card-title">Modo de renombrado</h3>
    </div>

    <fieldset class="strategy-group">
        <legend class="visually-hidden">Modo de renombrado</legend>

        <label class="strategy-option @(SelectedMode == RenameMode.Maintain ? "active" : "")" for="modeMaintain">
            <input class="strategy-input" type="radio" name="strategyMode" id="modeMaintain"
                checked="@(SelectedMode == RenameMode.Maintain)" @onchange="@(() => SelectMode(RenameMode.Maintain))">
            <span class="strategy-copy">
                <strong>Mantener estructura</strong>
                <small>Reutiliza la estructura actual y avanza el número de episodio automáticamente.</small>
            </span>
        </label>

        <label class="strategy-option @(SelectedMode == RenameMode.Change ? "active" : "")" for="modeChange">
            <input class="strategy-input" type="radio" name="strategyMode" id="modeChange"
                checked="@(SelectedMode == RenameMode.Change)" @onchange="@(() => SelectMode(RenameMode.Change))">
            <span class="strategy-copy">
                <strong>Cambiar estructura</strong>
                <small>Conserva el número detectado y aplica una nueva composición del nombre.</small>
            </span>
        </label>
    </fieldset>
</section>

@code {
    [Parameter]
    public RenameMode SelectedMode { get; set; }

    [Parameter]
    public EventCallback<RenameMode> OnModeChanged { get; set; }

    private async Task SelectMode(RenameMode mode)
    {
        if (SelectedMode != mode)
        {
            await OnModeChanged.InvokeAsync(mode);
        }
    }
}
