@page "/"
@using OrganizadorCapitulos.Maui.Components
@using OrganizadorCapitulos.Maui.ViewModels
@using organizadorCapitulos.Core.Enums
@using OrganizadorCapitulos.Maui.Services.Interfaces
@using System.ComponentModel
@inject HomeViewModel ViewModel
@inject Microsoft.JSInterop.IJSRuntime JS
@implements IDisposable

<div class="home-shell" @ondragover="HandleDragOver" @ondragover:preventDefault="true"
    @ondrop="HandleDrop" @ondrop:preventDefault="true" @ondragleave="HandleDragLeave">

    <!-- Drag Overlay -->
    @if (ViewModel.IsDragging)
    {
        <div class="drop-zone-overlay">
            <div class="drop-zone-overlay-text">
                <span class="overlay-title">Soltar carpetas</span>
                <span class="overlay-subtitle">Cárgalas aquí para empezar a organizar capítulos.</span>
            </div>
        </div>
    }

    <header class="workspace-header surface-panel surface-panel-hero">
        <div class="workspace-copy">
            <span class="workspace-kicker">Organizador inteligente</span>
            <h1 class="workspace-title">Organizador de capítulos</h1>
            <p class="workspace-subtitle">
                Carga carpetas, detecta metadatos, corrige episodios y prepara renombrado o movimiento con una vista
                clara del progreso.
            </p>
        </div>

        <div class="workspace-stats" aria-label="Resumen del proyecto actual">
            <div class="stat-card">
                <span class="stat-label">Archivos</span>
                <strong class="stat-value">@ViewModel.Files.Count</strong>
                <span class="stat-caption">detectados</span>
            </div>
            <div class="stat-card stat-card-accent">
                <span class="stat-label">Listos</span>
                <strong class="stat-value">@ViewModel.AnalyzedCount</strong>
                <span class="stat-caption">para renombrar</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Pendientes</span>
                <strong class="stat-value">@ViewModel.PendingCount</strong>
                <span class="stat-caption">sin analizar</span>
            </div>
        </div>
    </header>

    <section class="action-bar surface-panel" aria-label="Acciones principales">
        <!-- Primary Workflow Actions -->
        <div class="action-group action-group-primary">
            <button type="button" class="btn btn-primary action-button action-button-hero"
                @onclick="() => ViewModel.ShowFolderBrowserCommand.Execute(null)" aria-label="Cargar carpetas"
                data-shortcut="ctrl+o" title="Cargar carpetas (Ctrl+O)">
                <span class="action-icon" aria-hidden="true">📁</span>
                <span class="action-copy">
                    <strong>Cargar carpetas</strong>
                    <small>Importa archivos de video</small>
                </span>
            </button>

            <button type="button" class="btn btn-info action-button"
                @onclick="() => ViewModel.AnalyzeWithAICommand.Execute(null)"
                disabled="@(!ViewModel.Files.Any() || ViewModel.IsProcessing)" aria-label="Analizar archivos con IA"
                data-shortcut="ctrl+i" title="Analizar con IA (Ctrl+I)">
                <span class="action-icon" aria-hidden="true">🤖</span>
                <span class="action-copy">
                    <strong>Analizar con IA</strong>
                    <small>Detecta serie y episodio</small>
                </span>
            </button>

            <button type="button" class="btn btn-secondary action-button"
                @onclick="() => ViewModel.OpenTmdbSearchCommand.Execute(null)"
                disabled="@(!ViewModel.Files.Any() || ViewModel.IsProcessing)" aria-label="Buscar metadatos en TMDB"
                data-shortcut="ctrl+t" title="Buscar en TMDB (Ctrl+T)">
                <span class="action-icon" aria-hidden="true">🔍</span>
                <span class="action-copy">
                    <strong>Buscar en TMDB</strong>
                    <small>Completa metadatos</small>
                </span>
            </button>
        </div>

        <!-- Secondary Actions (Execution) -->
        <div class="action-group action-group-secondary">
            <button type="button" class="btn btn-success btn-lg action-button-cta"
                @onclick="() => ViewModel.RenameAllCommand.Execute(null)"
                disabled="@(ViewModel.AnalyzedCount == 0 || ViewModel.IsProcessing)" 
                aria-label="Renombrar todos los archivos listos"
                data-shortcut="ctrl+enter" title="Renombrar todo (Ctrl+Enter)">
                <span class="action-icon" aria-hidden="true">✨</span>
                <strong>Renombrar @ViewModel.AnalyzedCount archivo@(ViewModel.AnalyzedCount != 1 ? "s" : "")</strong>
            </button>
        </div>

        <!-- Utility Actions (collapsed) -->
        <div class="action-group action-group-utility">
            <div class="utility-dropdown">
                <button type="button" class="btn btn-ghost action-chip" 
                    title="Más acciones" aria-label="Menú de utilidades" aria-haspopup="true">
                    ⋮ Más
                </button>
            </div>

            <button type="button" class="btn btn-ghost action-chip-icon"
                @onclick="() => ViewModel.OpenOperationLogCommand.Execute(null)" 
                aria-label="Abrir historial de operaciones"
                data-shortcut="ctrl+h" title="Historial (Ctrl+H)">
                📋
            </button>

            <button type="button" class="theme-toggle"
                @onclick="async () => { await ViewModel.ThemeService.ToggleThemeAsync(); await InvokeAsync(StateHasChanged); }"
                title="Cambiar tema" 
                aria-label="@(ViewModel.ThemeService.IsDarkTheme ? "Cambiar a tema claro" : "Cambiar a tema oscuro")"
                data-shortcut="ctrl+d">
                <span class="theme-toggle-glyph" aria-hidden="true">@(ViewModel.ThemeService.IsDarkTheme ? "☀️" : "🌙")</span>
            </button>
            
            <button type="button" class="btn btn-ghost action-chip-icon"
                @onclick="() => ViewModel.OpenSettingsCommand.Execute(null)" 
                aria-label="Abrir configuración"
                data-shortcut="ctrl+comma" title="Preferencias (Ctrl+,)">
                ⚙️
            </button>
        </div>
    </section>

    <!-- Floating Quick Actions (context-aware) -->
    @if (ViewModel.Files.Any() && !ViewModel.IsProcessing)
    {
        <div class="quick-actions-fab" role="toolbar" aria-label="Acciones rápidas">
            @if (ViewModel.SelectedFile != null)
            {
                <button type="button" class="fab-button fab-button-primary"
                    @onclick="() => ViewModel.RenameSelectedCommand.Execute(null)"
                    aria-label="Renombrar archivo seleccionado (F2)"
                    title="Renombrar seleccionado (F2)">
                    <span class="fab-icon">✏️</span>
                    <span class="fab-label">Renombrar</span>
                </button>
            }
            
            @if (ViewModel.UndoRedo.CanUndo)
            {
                <button type="button" class="fab-button fab-button-secondary"
                    @onclick="() => ViewModel.UndoCommand.Execute(null)"
                    aria-label="Deshacer último cambio (Ctrl+Z)"
                    title="Deshacer @(ViewModel.UndoRedo.UndoCount) cambio@(ViewModel.UndoRedo.UndoCount != 1 ? "s" : "") (Ctrl+Z)">
                    <span class="fab-icon">↶</span>
                    <span class="fab-label">@ViewModel.UndoRedo.UndoCount</span>
                </button>
            }
            
            <button type="button" class="fab-button fab-button-tertiary"
                @onclick="() => ViewModel.OpenSaveAllCommand.Execute(null)"
                aria-label="Mover archivos a otra carpeta (Ctrl+M)"
                title="Mover archivos (Ctrl+M)">
                <span class="fab-icon">📦</span>
                <span class="fab-label">Mover</span>
            </button>
        </div>
    }

    <!-- Compact Context Bar (replaces desktop-hud) -->
    @if (ViewModel.Files.Any())
    {
        <section class="context-bar surface-panel" aria-label="Contexto actual" aria-live="polite">
            @if (ViewModel.SelectedFile != null)
            {
                <div class="context-card">
                    <span class="context-label">Seleccionado:</span>
                    <strong class="context-value" title="@ViewModel.SelectedFile.OriginalName">@TruncateFileName(ViewModel.SelectedFile.OriginalName, 40)</strong>
                    <span class="badge @GetBadgeClass(ViewModel.SelectedFile.Status)">@GetStatusLabel(ViewModel.SelectedFile.Status)</span>
                </div>
                
                @if (!string.IsNullOrEmpty(ViewModel.SelectedFile.NewName))
                {
                    <div class="context-divider">→</div>
                    <div class="context-card context-card-preview">
                        <span class="context-label">Nuevo nombre:</span>
                        <code class="context-value-preview" title="@ViewModel.SelectedFile.NewName">@TruncateFileName(ViewModel.SelectedFile.NewName, 40)</code>
                    </div>
                }
            }
            else
            {
                <div class="context-empty">
                    <span class="context-hint">💡 Tip: Selecciona un archivo de la lista para ver su vista previa aquí</span>
                </div>
            }
            
            <button type="button" class="btn-link-subtle" 
                @onclick="() => showShortcutsTooltip = !showShortcutsTooltip"
                aria-label="Ver atajos de teclado" title="Ver atajos (?)">
                ⌨️ Atajos
            </button>
        </section>
    }

    <!-- Progress Bar (visible during processing) -->
    @if (ViewModel.IsProcessing)
    {
        <section class="progress-card surface-panel" aria-live="polite">
            <div class="d-flex justify-content-between small mb-1">
                <span>@ViewModel.ProgressMessage</span>
                <div class="d-flex align-items-center gap-2">
                    <span>@ViewModel.ProgressCurrent / @ViewModel.ProgressTotal</span>
                    <button type="button" class="btn btn-sm btn-outline-danger"
                        @onclick="() => ViewModel.CancelOperationCommand.Execute(null)"
                        aria-label="Cancelar operación en curso" title="Cancelar">
                        Cancelar
                    </button>
                </div>
            </div>
            <div class="progress-container">
                <div class="progress-bar-custom" style="width: @ViewModel.ProgressPercent%"></div>
            </div>
        </section>
    }

    <div class="workspace-grid">
        <section class="surface-panel workspace-panel workspace-panel-list" aria-labelledby="files-title">
            <div class="panel-header panel-header-rich">
                <div>
                    <span class="panel-kicker">Biblioteca</span>
                    <h2 id="files-title" class="panel-title">Archivos</h2>
                </div>
                <span class="panel-meta">@ViewModel.FileCounts</span>
            </div>
            <div class="panel-content panel-content-fill">
                <FileList Files="@ViewModel.Files" OnFileSelected="@((f) => ViewModel.SelectFileCommand.Execute(f))" />
            </div>
        </section>

        <aside class="surface-panel workspace-panel workspace-panel-detail @(ViewModel.SelectedFile is null ? string.Empty : "detail-panel-active")"
            aria-labelledby="details-title">
            <div class="panel-header panel-header-rich">
                <div>
                    <span class="panel-kicker">Edición</span>
                    <h2 id="details-title" class="panel-title">Detalles del capítulo</h2>
                </div>
                <span class="panel-meta">@(ViewModel.SelectedFile is null ? "Sin selección" : "Archivo activo")</span>
            </div>
            <div class="panel-content panel-content-form">
                <DetailsForm SelectedFile="@ViewModel.SelectedFile"
                    OnChange="@(() => ViewModel.UpdatePreviewForFileCommand.Execute(null))" />
                <StrategySelector SelectedMode="@ViewModel.CurrentMode"
                    OnModeChanged="@((m) => ViewModel.ChangeModeCommand.Execute(m))" />
            </div>
        </aside>
    </div>

    <div class="status-bar" aria-live="polite">
        <span>@ViewModel.StatusMessage</span>
        <span>Actualizado @DateTime.Now.ToString("HH:mm")</span>
    </div>
</div>

@* Dialogs *@
@if (ViewModel.ShowingFolderBrowser)
{
    <FolderBrowserDialog IsSingleSelectionMode="false"
        OnAccept="@((folders) => ViewModel.LoadFoldersCommand.Execute(folders))"
        OnCancel="() => ViewModel.HideFolderBrowserCommand.Execute(null)" />
}

@if (ViewModel.ShowingSettings)
{
    <SettingsDialog OnClose="() => ViewModel.CloseSettingsCommand.Execute(null)" />
}

@if (ViewModel.ShowingTmdbSearch)
{
    <TmdbSearchDialog Files="@ViewModel.Files" OnSeriesSelected="@((s) => ViewModel.ApplySeriesMetadataCommand.Execute(s))"
        OnClose="() => ViewModel.CloseTmdbSearchCommand.Execute(null)" />
}

@if (ViewModel.ShowingSaveAll)
{
    <FolderBrowserDialog IsSingleSelectionMode="true" OnAccept="@((folders) => ViewModel.MoveFilesCommand.Execute(folders))"
        OnCancel="() => ViewModel.CloseSaveAllCommand.Execute(null)" />
}

@if (ViewModel.ShowingOperationLog)
{
    <OperationLogDialog OnClose="() => ViewModel.CloseOperationLogCommand.Execute(null)" />
}

@code {
    private bool showShortcutsTooltip = false;

    protected override async Task OnInitializedAsync()
    {
        // Provide JS runtime to the theme service (required for DOM updates)
        ViewModel.ThemeService.SetJsRuntime(JS);

        // Initialize services (theme, etc.) from the ViewModel
        await ViewModel.InitializeAsync();
        ViewModel.PropertyChanged += ViewModelPropertyChanged;

        // Subscribe to theme changes so the UI updates when theme toggles elsewhere
        if (ViewModel?.ThemeService != null)
        {
            ViewModel.ThemeService.ThemeChanged += OnThemeChanged;
        }
    }

    private void ViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnThemeChanged(bool _)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleDragOver(DragEventArgs e)
    {
        ViewModel.SetDragging(true);
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        ViewModel.SetDragging(false);
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        await ViewModel.HandleDropAsync();
    }

    private static string GetStatusLabel(FileStatus status) => status switch
    {
        FileStatus.Done => "Renombrado",
        FileStatus.Analyzed => "Listo",
        FileStatus.Error => "Con incidencia",
        _ => "Pendiente"
    };

    private static string GetBadgeClass(FileStatus status) => status switch
    {
        FileStatus.Done => "badge-success",
        FileStatus.Analyzed => "badge-info",
        FileStatus.Error => "badge-danger",
        _ => "badge-secondary"
    };

    private static string TruncateFileName(string fileName, int maxLength)
    {
        if (string.IsNullOrEmpty(fileName) || fileName.Length <= maxLength)
            return fileName;
        
        var extension = System.IO.Path.GetExtension(fileName);
        var nameWithoutExt = System.IO.Path.GetFileNameWithoutExtension(fileName);
        var truncated = nameWithoutExt.Length > (maxLength - extension.Length - 3)
            ? nameWithoutExt.Substring(0, maxLength - extension.Length - 3) + "..."
            : nameWithoutExt;
        
        return truncated + extension;
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= ViewModelPropertyChanged;
        if (ViewModel?.ThemeService != null)
        {
            ViewModel.ThemeService.ThemeChanged -= OnThemeChanged;
        }
    }
}