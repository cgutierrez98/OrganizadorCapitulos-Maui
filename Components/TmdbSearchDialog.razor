@using organizadorCapitulos.Core.Entities
@using organizadorCapitulos.Application.Services
@using OrganizadorCapitulos.Maui.Services
@using organizadorCapitulos.Core.Enums
@using System.Collections.ObjectModel
@inject organizadorCapitulos.Core.Interfaces.Services.IMetadataService MetadataService
@inject SettingsService Settings

<div class="modal fade show d-block modal-backdrop-themed" tabindex="-1" role="dialog" aria-modal="true"
    aria-labelledby="tmdb-dialog-title">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <div class="modal-title-group">
                    <span class="modal-kicker">Catálogo</span>
                    <h5 class="modal-title" id="tmdb-dialog-title">Buscar metadatos en TMDB</h5>
                    <p class="modal-subtitle">Busca la serie correcta y descarga títulos de episodios para los archivos cargados.</p>
                </div>
                <button type="button" class="btn-close" @onclick="Cancel" aria-label="Cerrar diálogo"></button>
            </div>
            <div class="modal-body">
                @if (!IsConfigured)
                {
                    <div class="alert alert-warning">
                        <strong>Configuración requerida:</strong> Por favor configura la API Key de TMDB en Configuración.
                    </div>
                }
                else
                {
                    <!-- Search Input -->
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" @bind="SearchQuery" @bind:event="oninput"
                            @onkeypress="OnKeyPress" placeholder="Nombre de la serie..." aria-label="Buscar serie en TMDB" />
                        <button class="btn btn-primary" @onclick="Search" disabled="@IsSearching" aria-label="Ejecutar búsqueda en TMDB">
                            @(IsSearching ? "Buscando..." : "Buscar")
                        </button>
                    </div>

                    <!-- Search Results -->
                    @if (SearchResults.Any())
                    {
                        <div class="list-group mb-3" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var series in SearchResults)
                            {
                                <button type="button"
                                    class="list-group-item list-group-item-action @(SelectedSeries?.Id == series.Id ? "active" : "")"
                                    @onclick="() => SelectSeries(series)">
                                    <strong>@series.Name</strong>
                                    @if (!string.IsNullOrEmpty(series.FirstAirDate))
                                    {
                                        <span class="text-muted small ms-2">(@series.FirstAirDate)</span>
                                    }
                                </button>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert @(IsError ? "alert-danger" : "alert-info") py-2 small">
                            @StatusMessage
                        </div>
                    }
                }
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" @onclick="Cancel">Cancelar</button>
                <button type="button" class="btn btn-success btn-sm" @onclick="FetchEpisodes"
                    disabled="@(SelectedSeries == null || IsFetching)">
                    @(IsFetching ? "Descargando..." : "Descargar Títulos")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ObservableCollection<OrganizadorCapitulos.Maui.Models.FileViewModel> Files { get; set; } = new();

    [Parameter]
    public EventCallback<string> OnSeriesSelected { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string SearchQuery = "";
    private List<SeriesSearchResult> SearchResults = new();
    private SeriesSearchResult? SelectedSeries;
    private string StatusMessage = "";
    private bool IsError = false;
    private bool IsSearching = false;
    private bool IsFetching = false;
    private bool IsConfigured = false;

    protected override void OnInitialized()
    {
        // Load saved API key from settings
        var apiKey = Settings.TmdbApiKey;
        if (!string.IsNullOrEmpty(apiKey))
        {
            MetadataService.Configure(apiKey);
        }
        IsConfigured = MetadataService.IsConfigured();
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery)) return;

        IsSearching = true;
        StatusMessage = "";
        SearchResults.Clear();
        SelectedSeries = null;
        StateHasChanged();

        try
        {
            SearchResults = await MetadataService.SearchSeriesAsync(SearchQuery);

            if (!SearchResults.Any())
            {
                StatusMessage = "No se encontraron resultados";
                IsError = false;
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsSearching = false;
        }
    }

    private void SelectSeries(SeriesSearchResult series)
    {
        SelectedSeries = series;
        StatusMessage = $"Serie seleccionada: {series.Name}";
        IsError = false;
    }

    private async Task FetchEpisodes()
    {
        if (SelectedSeries == null) return;

        IsFetching = true;
        StatusMessage = "Descargando títulos de episodios...";
        StateHasChanged();

        try
        {
            int total = Files.Count;
            int current = 0;
            int found = 0;

            foreach (var file in Files)
            {
                current++;
                StatusMessage = $"Procesando [{current}/{total}]: {file.OriginalName}";
                StateHasChanged();

                bool foundEpisode = false;

                // Method 1: Try to extract season/episode from filename
                if (EpisodePatternParser.TryExtractSeasonEpisode(file.OriginalName, out int season, out int episode))
                {
                    var title = await MetadataService.GetEpisodeTitleAsync(SelectedSeries.Id, season, episode);
                    if (!string.IsNullOrEmpty(title))
                    {
                        file.EpisodeTitle = title;
                        file.Season = season;
                        file.Episode = episode;
                        file.SeriesTitle = SelectedSeries.Name ?? "";
                        file.Status = FileStatus.Analyzed;
                        found++;
                        foundEpisode = true;
                    }
                }

                // Method 2: If no season/episode found, try to find by existing episode title
                if (!foundEpisode && !string.IsNullOrEmpty(file.EpisodeTitle))
                {
                    var result = await MetadataService.FindEpisodeByTitleAsync(SelectedSeries.Id, file.EpisodeTitle);
                    if (result.HasValue)
                    {
                        file.Season = result.Value.season;
                        file.Episode = result.Value.episode;
                        file.EpisodeTitle = result.Value.title;
                        file.SeriesTitle = SelectedSeries.Name ?? "";
                        file.Status = FileStatus.Analyzed;
                        found++;
                        foundEpisode = true;
                    }
                }

                // Method 3: Try extracting title from filename and search by that
                if (!foundEpisode)
                {
                    string possibleTitle = EpisodePatternParser.ExtractPossibleTitle(file.OriginalName);
                    if (!string.IsNullOrEmpty(possibleTitle))
                    {
                        var result = await MetadataService.FindEpisodeByTitleAsync(SelectedSeries.Id, possibleTitle);
                        if (result.HasValue)
                        {
                            file.Season = result.Value.season;
                            file.Episode = result.Value.episode;
                            file.EpisodeTitle = result.Value.title;
                            file.SeriesTitle = SelectedSeries.Name ?? "";
                            file.Status = FileStatus.Analyzed;
                            found++;
                        }
                    }
                }
            }

            StatusMessage = $"Completado: {found} títulos encontrados de {total} archivos";
            IsError = false;

            // Notificar el nombre de la serie
            if (SelectedSeries.Name != null)
            {
                await OnSeriesSelected.InvokeAsync(SelectedSeries.Name);
            }

            await Task.Delay(1500);
            await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsFetching = false;
        }
    }
    private async Task Cancel()
    {
        await OnClose.InvokeAsync();
    }
}