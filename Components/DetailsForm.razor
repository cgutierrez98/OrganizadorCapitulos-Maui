@using OrganizadorCapitulos.Maui.Models

@if (SelectedFile == null)
{
    <div class="empty-state empty-state-compact">
        <div class="empty-state-icon" aria-hidden="true">Editar</div>
        <div class="empty-state-copy">
            <h3>Selecciona un archivo</h3>
            <p>Cuando elijas un capítulo podrás revisar sus metadatos, el nombre sugerido y la estrategia de renombrado.</p>
        </div>
    </div>
}
else
{
    <div class="details-stack">
        <section class="editor-card">
            <div class="editor-card-header">
                <span class="panel-kicker">Metadatos</span>
                <h3 class="editor-card-title">Información del episodio</h3>
            </div>

            <div class="field-group">
                <label class="form-label field-label" for="series-title">Nombre de la serie</label>
                <input id="series-title" type="text" class="form-control" @bind="SelectedFile.SeriesTitle"
                    @bind:after="OnChanged" placeholder="Ej: Breaking Bad" />
            </div>

            <div class="field-grid">
                <div class="field-group">
                    <label class="form-label field-label" for="season-number">Temporada</label>
                    <input id="season-number" type="number" class="form-control" @bind="SelectedFile.Season"
                        @bind:after="OnChanged" min="1" />
                </div>
                <div class="field-group">
                    <label class="form-label field-label" for="episode-number">Episodio</label>
                    <input id="episode-number" type="number" class="form-control" @bind="SelectedFile.Episode"
                        @bind:after="OnChanged" min="1" />
                </div>
            </div>

            <div class="field-group">
                <label class="form-label field-label" for="episode-title">Título del episodio</label>
                <input id="episode-title" type="text" class="form-control" @bind="SelectedFile.EpisodeTitle"
                    @bind:after="OnChanged" placeholder="Ej: Pilot (opcional)" />
            </div>
        </section>

        <section class="editor-card">
            <div class="editor-card-header">
                <span class="panel-kicker">Resultado</span>
                <h3 class="editor-card-title">Vista previa del nuevo nombre</h3>
            </div>

            @if (!string.IsNullOrEmpty(SelectedFile.NewName))
            {
                <div class="preview-card" aria-live="polite">
                    <span class="preview-label">Nombre generado</span>
                    <code class="preview-value">@SelectedFile.NewName</code>
                </div>
            }
            else
            {
                <div class="preview-card preview-card-muted">
                    <span class="preview-label">Aún no disponible</span>
                    <p class="mb-0">Completa los campos o ejecuta el análisis para preparar una propuesta de nombre.</p>
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter]
    public FileViewModel? SelectedFile { get; set; }

    [Parameter]
    public EventCallback OnChange { get; set; }

    private async Task OnChanged()
    {
        await OnChange.InvokeAsync();
    }
}
