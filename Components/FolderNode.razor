@using System.IO

<div class="folder-node">
    <div class="d-flex align-items-center py-1 px-2 @(IsHovered ? "bg-light" : "")" 
         style="padding-left: @(Level * 20 + 8)px; cursor: pointer;"
         @onmouseenter="() => IsHovered = true"
         @onmouseleave="() => IsHovered = false">
        
        @* Expand/Collapse button *@
        @if (HasSubfolders)
        {
            <button class="btn btn-link btn-sm p-0 me-1 text-secondary" 
                    style="width: 20px;" 
                    @onclick="ToggleExpand"
                    @onclick:stopPropagation="true">
                @(IsExpanded ? "▼" : "▶")
            </button>
        }
        else
        {
            <span style="width: 20px; display: inline-block;"></span>
        }

        @* Checkbox *@
        <input type="checkbox" 
               class="form-check-input me-2" 
               checked="@IsSelected"
               @onchange="OnCheckChanged" />

        @* Folder icon and name *@
        <span @onclick="ToggleExpand" class="user-select-none">
            📁 @Name
        </span>
    </div>

    @* Children *@
    @if (IsExpanded && Subfolders.Any())
    {
        @foreach (var subfolder in Subfolders)
        {
            <FolderNode 
                Path="@subfolder.FullPath" 
                Name="@subfolder.Name" 
                Level="@(Level + 1)"
                SelectedFolders="@SelectedFolders"
                OnSelectionChanged="@OnSelectionChanged"
                IsSingleMode="@IsSingleMode" />
        }
    }
</div>

@code {
    [Parameter] public string Path { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int Level { get; set; } = 0;
    [Parameter] public HashSet<string> SelectedFolders { get; set; } = new();
    [Parameter] public EventCallback<(string path, bool isSelected)> OnSelectionChanged { get; set; }
    [Parameter] public bool IsSingleMode { get; set; } = false;

    private bool IsExpanded = false;
    private bool IsHovered = false;
    private bool HasSubfolders = true;
    private List<FolderInfo> Subfolders = new();
    private bool SubfoldersLoaded = false;

    private bool IsSelected => SelectedFolders.Contains(Path);

    private class FolderInfo
    {
        public string Name { get; set; } = "";
        public string FullPath { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        // Verificar si tiene subcarpetas (sin cargarlas aún)
        try
        {
            HasSubfolders = Directory.EnumerateDirectories(Path).Any();
        }
        catch
        {
            HasSubfolders = false;
        }
    }

    private void ToggleExpand()
    {
        IsExpanded = !IsExpanded;
        
        if (IsExpanded && !SubfoldersLoaded)
        {
            LoadSubfolders();
        }
    }

    private void LoadSubfolders()
    {
        try
        {
            Subfolders = Directory.GetDirectories(Path)
                .Select(d => new FolderInfo 
                { 
                    Name = System.IO.Path.GetFileName(d),
                    FullPath = d 
                })
                .OrderBy(f => f.Name)
                .ToList();
            
            SubfoldersLoaded = true;
        }
        catch
        {
            Subfolders = new List<FolderInfo>();
        }
    }

    private async Task OnCheckChanged(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        await OnSelectionChanged.InvokeAsync((Path, isChecked));
    }
}
